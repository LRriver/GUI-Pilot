# Copy this file to .env and fill in local credentials. Do not commit .env.
#
# GUI-Pilot reads process environment variables directly. It does not load
# `.env` automatically, so export these variables in your shell or load them
# with your preferred dotenv tool before running VLM calls.

VLM_API_KEY=

# Optional debug overrides. If unset, gui_pilot.schema uses the defaults below.
DEBUG_API_URL=https://ark.cn-beijing.volces.com/api/v3
DEBUG_MODEL_ID=doubao-seed-1-6-vision-250815
